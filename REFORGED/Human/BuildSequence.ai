//============================================================================
function init_strategy_Mortars takes nothing returns nothing
    call AddBlock(1, uBLACKSMITH, false, 1, uHOUSE, 60)
    call AddBlock(1, uBLACKSMITH, true, 0, uARCANE_VAULT, 60)


    call AddHarass(2, 2, uRIFLEMAN)
    set distraction_group = 2



























endfunction
function build_sequence_Mortars takes nothing returns nothing
if tier == 3 then

    call BuildUnit(8, uSPELL_BREAKER, 65)
    call BuildUnit(6, uPRIEST, 70)
    call BuildUnit(8, uRIFLEMAN, 60)
    call BuildUnit(10, uMORTAR, 65)
    call BuildUnit(5, uKNIGHT, 55)
    call BuildUnit(8, uSORCERESS, 60)
    if GetUpgradeLevel(uUPG_TANK) > 0 then
        call BuildUnit(5, uROCKET_TANK, 60)
    else
