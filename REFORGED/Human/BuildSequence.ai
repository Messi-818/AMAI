    call BuildUnit(8, uSORCERESS, 60)
    call BuildUnit(1, hero[1], 140)
    call BuildUnit(1, hero[2], 130)
    call BuildUnit(1, hero[3], 120)
    
    call BuildUpgr(2, uUPG_PRAYING, 85)
    call BuildUpgr(1, uUPG_GUN_RANGE, 90)
    call BuildUpgr(1, uUPG_CONT_MAGIC, 85)
    call BuildUpgr(1, uUPG_HAMMERS, 70)
    call BuildUpgr(1, uUPG_BREEDING, 80)
    call BuildUpgr(2, uUPG_SORCERY, 75) 




























elseif tier == 2 then
    call BuildUnit(10, uRIFLEMAN, 55)
    call BuildUnit(4, uSPELL_BREAKER, 65)
    call BuildUnit(4, uPRIEST, 65)
    call BuildUnit(2, uMORTAR, 60)
    call BuildUnit(6, uSORCERESS, 60)
    call BuildUnit(1, hero[1], 140)
    call BuildUnit(1, hero[2], 130)
    call BuildUnit(1, uCASTLE, 70)
    call BuildUpgr(1, uUPG_GUN_RANGE, 80)
    call BuildUpgr(1, uUPG_PRAYING, 75)
    call BuildUpgr(1, uUPG_SORCERY, 80)





























else

    call BuildUnit(6, uRIFLEMAN, 55)
    call BuildUnit(4, uFOOTMAN, 60)
    call BuildUnit(1, hero[1], 150)
    call BuildUnit(1, uKEEP, 65)






























endif
endfunction

//============================================================================
