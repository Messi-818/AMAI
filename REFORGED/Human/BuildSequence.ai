    call AddBlock(1, uBLACKSMITH, false, 1, uHOUSE, 60)
    call AddBlock(1, uBLACKSMITH, false, 9, uPEASANT, 60)
    call AddBlock(1, uBLACKSMITH, true, 0, uARCANE_VAULT, 60)

    call AddHarass(2, 2, uRIFLEMAN)
    set distraction_group = 2


























endfunction
