//============================================================================
//  global builds
//============================================================================
function global_init_strategy takes nothing returns nothing
    call SetTierBlock(1, 0.75, 60, true)
    call SetTierBlock(2, 0.75, 90, true)
    if not IsMapFlagSet(MAP_RANDOM_HERO) then
      call AddBlock(1, uHUMAN_ALTAR, false, 0, uARCANE_VAULT, 16)
      call AddBlock(1, uHUMAN_ALTAR, false, 0, uHOUSE, 16)
      call AddBlock(1, uHUMAN_ALTAR, false, 0, uBARRACKS, 16)
    endif
    call AddBlock(2, uHOUSE, true, 0, uARCANE_VAULT, 36)
    call AddBlock(1, uBARRACKS, false, 0, uLUMBER_MILL, 20)
    call AddBlock(1, uBARRACKS, true, 0, uARCANE_VAULT, 36)
    call AddBlock(1, uBARRACKS, false, 0, uBLACKSMITH, 20)
    call AddBlock(1, uBLACKSMITH, true, 0, uWATCH_TOWER, 36)
    call AddHarass(1, 2, uFOOTMAN)
    call AddHarass(1, 2, uGRYPHON)
    call AddHarass(1, 1, uPALADIN)

























































endfunction
function global_build_sequence takes nothing returns nothing
    
   if GetRushFactor() < 5000 then
       call BuildUnit(2, uARCANE_TOWER, 55)
       call BuildAtMine(1, uGUARD_TOWER, 45)
   endif
   if tier == 1 and TownCountDone(uHUMAN_ALTAR) >= 1 and GetGold() > 200 then  
       call BuildUnit(2, uHOUSE, 80)
   endif
    if GetGold() > 500 then
       call BuildFront(2, uGUARD_TOWER, 50)
       call BuildFront(2, uARCANE_TOWER, 55)
   endif
   if HasExpanded() then
       call DefendTownsDone(2, uGUARD_TOWER, 65)
       call DefendTownsDone(3, uHOUSE, 60)
       call DefendTowns(1, uARCANE_VAULT, 80)
   endif
   if TownCount(uWORKSHOP) >= 1 then
        call BuildFront(2, uCANNON_TOWER, 55)
   endif


    // Global Items
      call BuildItem(1, uSCROLL_OF_REGENERATION, 90)
      call BuildItem(1, uM_SCROLL_OF_HEALING, 40)
      call BuildItem(1, uSCROLL_OF_PROTECTION, 40)
      call BuildItem(1, uPOTION_OF_LESSER_INVULNERBILITY, 75)
      call BuildItem(1, uLESSER_CLARITY_POTION, 35)
      call BuildItem(1, uBOOTS_OF_SPEED, 90)
      call BuildItem(1, uM_TOWN_PORTAL, 100)
      if tier >= 2 then
            call BuildItem(1, uHEALING_POTION, 80)
            call BuildItem(1, uTOWN_PORTAL, 150)
            call BuildItem(1, uSTAFF_OF_PRESERVATION,120)
      endif
      if tier >= 3 then
            call BuildItem(1, uSTAFF_OF_SANCTUARY, 120)
            call BuildItem(1, uORB_OF_SLOW, 100)
      endif
      if GetGold() > 1000 then
            call BuildItem(1, uSTAFF_OF_TELEPORTATION, 35)
      endif
	// DYNAMIC
	call ResetDynamicSystem()
	if tier == 1 then
		call AddUnitToAntiair(uRIFLEMAN,29)
		call AddUnitToAnticasters(uRIFLEMAN,29)
		call AddUnitToAntitowers(uFOOTMAN,29)
		call AddUnitToAntipiercing(uFOOTMAN, 29)
		call AddUnitToAntinormal(uFOOTMAN, 5)
		call AddUnitToAntisiege(uRIFLEMAN,10)
		call AddUnitToAntisiege(uFOOTMAN,5)
		call AddUnitToAntimagic(uRIFLEMAN,29)
		call AddUnitToAntiunarmored(uRIFLEMAN,29)
		call AddUnitToAntilightarmor(uRIFLEMAN,29)
		call AddUnitToAntimediumarmor(uFOOTMAN,5)
		call AddUnitToAntiheavyarmor(uFOOTMAN,29)
		call DynamicBuildUnit(32, 40)
		call BuildUnit(1, merc_range, 65)
		call BuildUnit(1, merc_healer, 65)
	elseif tier == 2 then
		call AddUnitToAntiair(uRIFLEMAN,15)
		call AddUnitToAntiair(uCOPTER,2+GetUpgradeLevel(old_id[uUPG_FLAK]))
		call AddUnitToAntiair(uHUMAN_DRAGON_HAWK,5)
		call AddUnitToAnticasters(uSPELL_BREAKER,4+GetUpgradeLevel(old_id[uUPG_CONT_MAGIC]))
		call AddUnitToAnticasters(uPRIEST,GetUpgradeLevel(old_id[uUPG_PRAYING]))
		call AddUnitToAntitowers(uMORTAR,40)
		//call AddUnitToAntitowers(uHUMAN_DRAGON_HAWK,10)  // need tier 3 uUPG_CLOUD
		call AddUnitToAntipiercing(uSPELL_BREAKER, 7)
		call AddUnitToAntipiercing(uRIFLEMAN, 5)
		call AddUnitToAntinormal(uFOOTMAN, 5)
        call AddUnitToAntinormal(uMORTAR,10)
		call AddUnitToAntisiege(uRIFLEMAN,2)
		call AddUnitToAntisiege(uSPELL_BREAKER,10)
		call AddUnitToAntimagic(uRIFLEMAN,5)
		call AddUnitToAntimagic(uSPELL_BREAKER,3)
		call AddUnitToAntiunarmored(uRIFLEMAN,9)
		call AddUnitToAntiunarmored(uMORTAR,15)
		call AddUnitToAntiunarmored(uHUMAN_DRAGON_HAWK,5)
		call AddUnitToAntilightarmor(uRIFLEMAN,25)
		call AddUnitToAntilightarmor(uHUMAN_DRAGON_HAWK,15)
		call AddUnitToAntilightarmor(uSORCERESS,5)
		call AddUnitToAntilightarmor(uPRIEST,5)
		call AddUnitToAntimediumarmor(uFOOTMAN,5)
		call AddUnitToAntiheavyarmor(uSORCERESS,15)
		call AddUnitToAntiheavyarmor(uPRIEST,12)
		call DynamicBuildUnit(64, 40)
		call BuildUnit(1, dragons[3], 65)
		call BuildUnit(1, merc_range, 65)
	else
		call AddUnitToAntiair(uRIFLEMAN,10)
		call AddUnitToAntiair(uCOPTER,2+GetUpgradeLevel(old_id[uUPG_FLAK]))
		call AddUnitToAntiair(uHUMAN_DRAGON_HAWK,5)
		call AddUnitToAntiair(uROCKET_TANK,GetUpgradeLevel(old_id[uUPG_TANK]))
        if GetUpgradeLevel(uUPG_TANK) > 0 then
			call AddUnitToAntiair(uROCKET_TANK,5)
		else
			call AddUnitToAntiair(TANK,5)
		endif
		call AddUnitToAnticasters(uSPELL_BREAKER,5+GetUpgradeLevel(old_id[uUPG_CONT_MAGIC]))
		call AddUnitToAnticasters(uPRIEST,5)
		call AddUnitToAntitowers(uMORTAR,15)
		call AddUnitToAntitowers(uHUMAN_DRAGON_HAWK,1)
		call AddUnitToAntitowers(uCOPTER,2*GetUpgradeLevel(old_id[uUPG_BOMBS]))
		call AddUnitToAntipiercing(uSPELL_BREAKER, 22)
		call AddUnitToAntipiercing(uKNIGHT, 20)
		call AddUnitToAntinormal(uKNIGHT, 10)
        call AddUnitToAntinormal(uMORTAR,12)
        call AddUnitToAntinormal(uGRYPHON,25)
		call AddUnitToAntisiege(uRIFLEMAN,5)
		call AddUnitToAntisiege(uSPELL_BREAKER,1)
        call AddUnitToAntisiege(uGRYPHON,20)
		call AddUnitToAntimagic(uRIFLEMAN,15)
		call AddUnitToAntimagic(uSPELL_BREAKER,10)
		call AddUnitToAntiunarmored(uRIFLEMAN,6)
		call AddUnitToAntiunarmored(uMORTAR,15)
		call AddUnitToAntiunarmored(uHUMAN_DRAGON_HAWK,2)
		call AddUnitToAntilightarmor(uRIFLEMAN,25)
		call AddUnitToAntilightarmor(uHUMAN_DRAGON_HAWK,7)
		call AddUnitToAntilightarmor(uSORCERESS,5)
		call AddUnitToAntilightarmor(uPRIEST,5)
		call AddUnitToAntilightarmor(uGRYPHON,5)
		call AddUnitToAntimediumarmor(uKNIGHT,15)
        call AddUnitToAntimediumarmor(uSPELL_BREAKER,10)
        call AddUnitToAntimediumarmor(uMORTAR,15)
		call AddUnitToAntiheavyarmor(uSORCERESS,8)
		call AddUnitToAntiheavyarmor(uGRYPHON,25)
		call AddUnitToAntiheavyarmor(uPRIEST,5)
		call DynamicBuildUnit(100, 40)
		call BuildUnit(1, dragons[3], 65)
	endif

    // Global Upgrades

	// TIER 1 UPGRADES
	//--------------------------------------------------------
    if tier >= 1 then
    endif
    call BuildAdvUpgr2(1, uUPG_DEFEND, 1,TownCountDone(uFOOTMAN), 0.33, 15, 50)
    call BuildAdvUpgr(1, uUPG_WOOD,1,1,1,5,65)
    call BuildAdvUpgr(3, uUPG_MASONRY,1,1,1,5,20)
    call BuildAdvUpgr2(3, uUPG_MELEE, 1,TownCountDone(uFOOTMAN) + TownCountDone(uKNIGHT) + TownCountDone(uSPELL_BREAKER) + TownCountDone(uHUMAN_DRAGON_HAWK) + TownCountDone(uGRYPHON), 5,15,40)
    call BuildAdvUpgr2(3, uUPG_ARMOR, 1,TownCountDone(uFOOTMAN) + TownCountDone(uKNIGHT) + TownCountDone(uSPELL_BREAKER) + TownCountDone(uCOPTER) + TownCountDone(TANK), 5,15,40)
    call BuildAdvUpgr2(3, uUPG_RANGED, 1,TownCountDone(uRIFLEMAN) + TownCountDone(uCOPTER) + TownCountDone(TANK) + TownCountDone(uMORTAR), 3,15,40)
    call BuildAdvUpgr2(3, uUPG_LEATHER, 1,TownCountDone(uRIFLEMAN) + TownCountDone(uGRYPHON) + TownCountDone(uHUMAN_DRAGON_HAWK) + TownCountDone(uMORTAR), 3,15,40)

    // TIER 2 UPGRADES
    //--------------------------------------------------------
    if tier >= 2 then
    endif
    call BuildAdvUpgr2(1, uUPG_SENTINEL, 2, TownCountDone(uWATCH_TOWER) + c_enemy[R_ELF],2, 10, 45) 
    call BuildAdvUpgr2(1, uUPG_FLAK, 2,TownCountDone(uCOPTER),0.33,15, 55)
    call BuildAdvUpgr2(1, uUPG_GUN_RANGE, 2,TownCountDone(uRIFLEMAN),1,10, 75)
    call BuildAdvUpgr2(1, uUPG_SIGHT, 2,TownCountDone(uMORTAR),1,10, 30)
    call BuildAdvUpgr2(2, uUPG_PRAYING, 2,TownCountDone(uPRIEST), 0.33, 15, 95)
    call BuildAdvUpgr2(2, uUPG_SORCERY,2,TownCountDone(uSORCERESS), 0.33, 15, 95)
    if GetMinesOwned() > 1 then
      if TownCountDone(uWATCH_TOWER) >= 2 then
        call BuildUpgr(1, oGUARD_TOWER, 45)
        call BuildUpgr(1, oARCANE_TOWER, 50)
      endif
      if TownCountDone(uWATCH_TOWER) >= 2 then
        call BuildUpgr(2, oGUARD_TOWER, 50)
      endif
    endif


    // TIER 3 UPGRADES
    //--------------------------------------------------------
    if tier == 3 then
    endif
    call BuildAdvUpgr2(1, uUPG_CONT_MAGIC, 3,TownCountDone(uSPELL_BREAKER), 0.5, 10, 60)
    call BuildAdvUpgr2(1, uUPG_BOMBS, 3,TownCountDone(uCOPTER),1,15, 45)
    call BuildAdvUpgr2(1, uUPG_FRAGS, 3,TownCountDone(uMORTAR), 0.33,15, 85)
    call BuildAdvUpgr2(1, uUPG_HAMMERS, 3,TownCountDone(uGRYPHON), 0.33,15, 75)
    call BuildAdvUpgr2(1, uUPG_BREEDING, 3,TownCountDone(uKNIGHT) + TownCountDone(uGRYPHON) + TownCountDone(uHUMAN_DRAGON_HAWK),1,15, 80)
    call BuildAdvUpgr2(1, uUPG_TANK, 3, TownCountDone(TANK),0.25,15, 70)
    call BuildAdvUpgr2(1, uUPG_CLOUD, 3, TownCountDone(uHUMAN_DRAGON_HAWK),0.33,15, 70)
    if enemy_mediumarmor > 0 then
      call BuildAdvUpgr2(1, uUPG_SUN_BLADE, 3, TownCountDone(uKNIGHT),0.33,15,70)
    endif
      // Global Mercenaries

    // Harass
    if not towerrush and not town_threatened then
      call Harass(1, HARASS_TARGET_PEONS, true, 5, 0.75, 0, GetPlayerRace(nearest_enemy) != RACE_UNDEAD , 50, 80)
      call Harass(3, HARASS_TARGET_PEONS, true, 5, 0.75, 0, GetPlayerRace(nearest_enemy) != RACE_UNDEAD , 80, 100)
      call Harass(4, HARASS_TARGET_PEONS, true, 4, 0.1, 0, GetPlayerRace(nearest_enemy) == RACE_UNDEAD and GetUnitCountDone(old_id[uPALADIN]) > 0 , 50, 80)
    endif

































































endfunction

//============================================================================
//  build_sequence
//============================================================================
function init_strategy_NormalHuman takes nothing returns nothing

    call AddHarass(2, 4, uFOOTMAN)
    set distraction_group = 2





















endfunction
function build_sequence_NormalHuman takes nothing returns nothing
if tier == 3 then

    call BuildUnit(1, hero[1], 140)
    call BuildUnit(1, hero[2], 130)
    call BuildUnit(1, hero[3], 120)
    call BuildUnit(10, uSPELL_BREAKER, 70)
    call BuildUnit(8, uPRIEST, 70)
    call BuildUnit(8, uRIFLEMAN, 65)
    call BuildUnit(6, uMORTAR, 60)
    call BuildUnit(8, uKNIGHT, 55)
    call BuildUnit(5, uSORCERESS, 65)
    call BuildUnit(10, uCOPTER, 45)
    call BuildUnit(4, uGRYPHON, 55)
    if GetUpgradeLevel(uUPG_TANK) > 0 then
        call BuildUnit(4, uROCKET_TANK, 60)
    else
        call BuildUnit(4, TANK, 61)
    endif
    call BuildUpgr(2, uUPG_PRAYING, 85)
    call BuildUpgr(1, uUPG_CONT_MAGIC, 90)
    call BuildUpgr(1, uUPG_GUN_RANGE, 85)
    call BuildUpgr(2, uUPG_SORCERY, 80)
    call BuildUpgr(1, uUPG_TANK, 65)
    call BuildUpgr(1, uUPG_FLAK, 80)
    call BuildUpgr(1, uUPG_HAMMERS, 75)





















elseif tier == 2 then

    call BuildUnit(1, uCASTLE, 75)
    call BuildUnit(1, hero[1], 140)
    call BuildUnit(1, hero[2], 130)
    call BuildUnit(5, uSPELL_BREAKER, 70)
    call BuildUnit(4, uPRIEST, 65)
    call BuildUnit(6, uRIFLEMAN, 65)
    call BuildUnit(4, uMORTAR, 60)
    call BuildUnit(3, uSORCERESS, 60)
    call BuildUpgr(1, uUPG_PRAYING, 75)
    call BuildUpgr(1, uUPG_GUN_RANGE, 80)
    call BuildUpgr(1, uUPG_SORCERY, 65)























else

    call BuildUnit(1, hero[1], 150)
    call BuildUnit(6, uFOOTMAN, 60)
    call BuildUnit(4, uRIFLEMAN, 50)
    call BuildUnit(1, uKEEP, 65)






















endif
endfunction

